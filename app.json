{
  "expo": {
    "name": "Rengage",
    "slug": "rengage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "rengage",
    "splash": {
      "backgroundColor": "#111318"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sheffco.rengage",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111318"
      },
      "package": "com.sheffco.rengage"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "Rengage imports screenshots you take of your app so it can suggest them as social media visuals.",
          "savePhotosPermission": "Rengage saves marketing images to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c8b3a95a-1329-4820-8163-2bca799f0066"
      }
    },
    "owner": "brandolee80"
  }
}
